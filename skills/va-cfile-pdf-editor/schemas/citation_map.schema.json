{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "citation_map.schema.json",
  "type": "object",
  "required": ["case_id", "citations"],
  "properties": {
    "case_id": {"type": "string"},
    "citations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "row_id",
          "timeline_type",
          "event_id",
          "source_pdf",
          "source_page",
          "quote",
          "bbox_id",
          "entity_id"
        ],
        "properties": {
          "row_id": {"type": "string"},
          "timeline_type": {"type": "string", "minLength": 1},
          "event_id": {"type": "string"},
          "source_pdf": {"type": "string"},
          "source_page": {"type": "integer", "minimum": 1},
          "quote": {"type": "string"},
          "bbox_id": {"type": "string"},
          "entity_id": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
