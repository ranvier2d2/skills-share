{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "edit_intent.schema.json",
  "type": "object",
  "required": ["case_id", "generated_from", "pages"],
  "properties": {
    "case_id": {"type": "string"},
    "generated_from": {
      "type": "string",
      "enum": ["raw_extraction", "auto_filtered_intents", "reviewed_intents"]
    },
    "uncertainties": {"type": "array", "items": {"type": "string"}},
    "pages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["page_id", "input_filename", "operations"],
        "properties": {
          "page_id": {"type": "string"},
          "input_filename": {"type": "string"},
          "operations": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "op",
                "params",
                "reason",
                "priority",
                "requires_review",
                "confidence"
              ],
              "properties": {
                "op": {
                  "type": "string",
                  "enum": [
                    "crop",
                    "rotate",
                    "deskew",
                    "contrast",
                    "denoise",
                    "redact_box",
                    "draw_box",
                    "draw_label"
                  ]
                },
                "params": {"type": "object"},
                "reason": {"type": "string"},
                "source_entity_id": {"type": "string", "minLength": 1},
                "entity_type": {"type": "string", "minLength": 1},
                "label": {"type": "string", "minLength": 1},
                "style": {"type": "string", "enum": ["legal", "medical", "metadata", "redaction"]},
                "priority": {"type": "integer", "minimum": 0, "maximum": 100},
                "requires_review": {"type": "boolean"},
                "confidence": {"type": "number", "minimum": 0, "maximum": 1}
              },
              "allOf": [
                {
                  "if": {"properties": {"op": {"const": "draw_box"}}},
                  "then": {"required": ["source_entity_id", "entity_type", "label", "style"]}
                },
                {
                  "if": {"properties": {"op": {"const": "draw_label"}}},
                  "then": {"required": ["source_entity_id", "entity_type", "label", "style"]}
                },
                {
                  "if": {"properties": {"op": {"const": "redact_box"}}},
                  "then": {"required": ["source_entity_id", "entity_type", "label", "style"]}
                }
              ],
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
