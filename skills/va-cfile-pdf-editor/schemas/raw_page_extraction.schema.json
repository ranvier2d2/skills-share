{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "raw_page_extraction.schema.json",
  "type": "object",
  "required": [
    "page_id",
    "source_pdf",
    "source_page",
    "analysis_pass",
    "entities",
    "events",
    "edit_intent_candidates",
    "uncertainties"
  ],
  "properties": {
    "page_id": {"type": "string"},
    "source_pdf": {"type": "string"},
    "source_page": {"type": "integer", "minimum": 1},
    "analysis_pass": {"type": "string", "enum": ["raw"]},
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "entity_id",
          "entity_type",
          "bbox",
          "text",
          "confidence",
          "chronology_role",
          "redaction_recommended"
        ],
        "properties": {
          "entity_id": {"type": "string"},
          "entity_type": {"type": "string"},
          "bbox": {
            "type": "object",
            "required": ["x", "y", "w", "h"],
            "properties": {
              "x": {"type": "number"},
              "y": {"type": "number"},
              "w": {"type": "number", "exclusiveMinimum": 0},
              "h": {"type": "number", "exclusiveMinimum": 0}
            },
            "additionalProperties": false
          },
          "text": {"type": "string"},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "chronology_role": {"type": "string", "minLength": 1},
          "redaction_recommended": {"type": "boolean"}
        },
        "additionalProperties": false
      }
    },
    "document_date": {
      "type": ["object", "null"],
      "properties": {
        "value": {"type": ["string", "null"]},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1}
      },
      "required": ["value", "confidence"],
      "additionalProperties": false
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "event_id",
          "event_type",
          "summary",
          "date",
          "date_confidence",
          "confidence",
          "condition_tags",
          "evidence"
        ],
        "properties": {
          "event_id": {"type": "string"},
          "event_type": {"type": "string", "minLength": 1},
          "summary": {"type": "string"},
          "actor": {"type": ["string", "null"]},
          "date": {"type": ["string", "null"]},
          "date_confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "condition_tags": {"type": "array", "items": {"type": "string"}},
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["quote", "bbox_id", "page_ref"],
              "properties": {
                "quote": {"type": "string"},
                "bbox_id": {"type": "string"},
                "page_ref": {"type": "string"},
                "entity_id": {"type": "string"}
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "edit_intent_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "op",
          "params",
          "reason",
          "source_entity_id",
          "entity_type",
          "label",
          "style",
          "priority",
          "requires_review",
          "confidence"
        ],
        "properties": {
          "op": {
            "type": "string",
            "enum": [
              "crop",
              "rotate",
              "deskew",
              "contrast",
              "denoise",
              "redact_box",
              "draw_box",
              "draw_label"
            ]
          },
          "params": {"type": "object"},
          "reason": {"type": "string"},
          "source_entity_id": {"type": "string"},
          "entity_type": {"type": "string"},
          "label": {"type": "string"},
          "style": {"type": "string", "enum": ["legal", "medical", "metadata", "redaction"]},
          "priority": {"type": "integer", "minimum": 0, "maximum": 100},
          "requires_review": {"type": "boolean"},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1}
        },
        "additionalProperties": false
      }
    },
    "uncertainties": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
